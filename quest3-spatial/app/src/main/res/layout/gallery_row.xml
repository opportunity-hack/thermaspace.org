<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:gravity="center_vertical">

    <CheckBox
        android:id="@+id/row_check"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="36dp" />

    <ImageView
        android:id="@+id/row_thumb"
        android:layout_width="72dp"
        android:layout_height="54dp"
        android:scaleType="fitCenter"
        android:contentDescription="thermal thumbnail" />

    <!-- real-world photo from the FLIR's visible camera (context) -->
    <ImageView
        android:id="@+id/row_thumb_vis"
        android:layout_width="72dp"
        android:layout_height="54dp"
        android:layout_marginStart="4dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:contentDescription="photo thumbnail" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="10dp">

        <TextView android:id="@+id/row_name"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="15sp" android:singleLine="true"
            android:text="name" />
        <TextView android:id="@+id/row_sub"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#9FB0C0" android:textSize="12sp" android:singleLine="true"
            android:text="sub" />
    </LinearLayout>

    <Button android:id="@+id/row_recall" style="@style/PanelButton"
        android:layout_width="wrap_content" android:layout_weight="0"
        android:text="Recall" />
    <Button android:id="@+id/row_rename" style="@style/PanelButton"
        android:layout_width="wrap_content" android:layout_weight="0"
        android:text="✎" />
    <Button android:id="@+id/row_delete" style="@style/PanelButton"
        android:layout_width="wrap_content" android:layout_weight="0"
        android:text="🗑" />
</LinearLayout>
