<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/hint_card"
    android:padding="10dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RIGHT CONTROLLER"
        android:textColor="#8FA3B8"
        android:textSize="10sp"
        android:letterSpacing="0.2"
        android:paddingBottom="6dp" />

    <LinearLayout style="@style/HintRow">
        <TextView style="@style/HintChip" android:background="@drawable/hint_chip_alt"
            android:text="TRIG" />
        <TextView android:id="@+id/hint_r_trigger" style="@style/HintLabel"
            android:text="hold — ✏️ Draw in the air" />
    </LinearLayout>

    <LinearLayout style="@style/HintRow">
        <TextView style="@style/HintChip" android:text="A" />
        <TextView style="@style/HintLabel" android:text="👁 Thermal overlay on/off" />
    </LinearLayout>

    <LinearLayout style="@style/HintRow">
        <TextView style="@style/HintChip" android:text="B" />
        <TextView style="@style/HintLabel" android:text="✏️ Draw mode on/off" />
    </LinearLayout>

    <LinearLayout style="@style/HintRow">
        <TextView style="@style/HintChip" android:text="🕹" />
        <TextView style="@style/HintLabel" android:text="click 📸 ・ aim+⇅⇄ move drawing" />
    </LinearLayout>

    <LinearLayout style="@style/HintRow">
        <TextView style="@style/HintChip" android:background="@drawable/hint_chip_alt"
            android:text="GRIP" />
        <TextView style="@style/HintLabel" android:text="✋ Grab things" />
    </LinearLayout>
</LinearLayout>
