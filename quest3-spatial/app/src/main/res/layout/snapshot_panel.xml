<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/snap_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:alpha="0.8"
        android:contentDescription="Thermal snapshot" />

    <!-- live-lock toggle: only visible on placed captures (never on recalled
         gallery copies) — locked captures refresh from the camera when gazed -->
    <Button
        android:id="@+id/snap_lock"
        android:layout_width="64dp"
        android:layout_height="52dp"
        android:layout_gravity="top|start"
        android:layout_margin="8dp"
        android:textSize="20sp"
        android:padding="0dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:backgroundTint="#99202830"
        android:text="🔓"
        android:visibility="gone"
        android:contentDescription="Live-lock this capture" />
</FrameLayout>
